{
  "name": "nexa-signal",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start:web": "npm --workspace @nexa/mobile run start:web",
    "start:web:8104": "npm --workspace @nexa/mobile run start:web:8104",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "eslint . --ext .ts,.tsx,.mts --max-warnings=0",
    "test": "vitest run",
    "format:check": "prettier --check .",
    "test:engine": "vitest run packages/game-engine/tests",
    "check:architecture": "tsx scripts/check-architecture-boundaries.ts",
    "check:i18n": "tsx scripts/check-i18n.ts",
    "check:release-config": "tsx scripts/check-release-config.ts",
    "check:production-guards": "tsx scripts/check-production-guards.ts",
    "check:release": "npm run typecheck && npm run lint && npm run test && npm run test:engine && npm run check:architecture && npm run check:i18n && npm run check:release-config && npm run check:production-guards && npm run format:check",
    "verify": "npm run check:release"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-native": "^0.73.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "eslint-plugin-import": "^2.31.0",
    "glob": "^11.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "react-dom": "19.2.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "overrides": {
    "react-native-worklets": "0.7.4"
  }
}
